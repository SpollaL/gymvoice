<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipChildren="false">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text"
        android:paddingTop="24dp"
        android:paddingStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTodayLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/today_logs"
        android:textSize="11sp"
        android:textColor="@color/subtext0"
        android:paddingStart="20dp"
        android:paddingTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvTodayLabel"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/subtext0"
        android:textSize="13sp"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnManualEntry"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManualEntry"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/log_manually"
        android:textColor="@color/subtext0"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/tvVoiceHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvVoiceHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/voice_format_hint"
        android:textSize="11sp"
        android:textColor="@color/overlay0"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintBottom_toTopOf="@id/btnRecord"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Record button tap target -->
    <FrameLayout
        android:id="@+id/btnRecord"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:clickable="true"
        android:focusable="true"
        android:clipChildren="false"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/tvRecordLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Pulsing ring, initially invisible -->
        <View
            android:id="@+id/pulseRing"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:background="@drawable/bg_record_ring"
            android:alpha="0" />

        <!-- Processing spinner, orbits around inner circle -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressSpinner"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorSize="88dp"
            app:trackThickness="2dp"
            app:indicatorColor="@color/accent"
            app:trackColor="@android:color/transparent" />

        <!-- Inner circle with icon -->
        <ImageView
            android:id="@+id/ivRecordIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_record_inner"
            android:backgroundTint="@color/accent"
            android:src="@drawable/ic_mic"
            android:tint="@color/text"
            android:padding="18dp"
            android:scaleType="fitCenter"
            android:elevation="8dp"
            android:outlineProvider="background"
            android:contentDescription="Record" />

    </FrameLayout>

    <!-- State label below button -->
    <TextView
        android:id="@+id/tvRecordLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/record_label_idle"
        android:textSize="12sp"
        android:letterSpacing="0.04"
        android:textColor="@color/subtext0"
        android:layout_marginBottom="44dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
